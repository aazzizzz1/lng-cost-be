// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  email    String  @unique
  password String
  role     String  @default("user")
  refreshToken String?
  createdAt DateTime @default(now())
  // NEW: each user can own many projects
  projects Project[]
}

model Project {
  id         Int      @id @default(autoincrement())
  name       String
  infrastruktur String?
  kategori   String
  lokasi     String
  tahun      Int
  levelAACE  Int      @default(0) // Auto-calculated based on construction costs
  harga      Float    @default(0) // Auto-calculated based on construction costs
  satuan     String?
  volume     Float?    // New field for project volume
  inflasi    Float?   @default(0) // Optional project inflation
  createdAt  DateTime @default(now()) // Add createdAt field
  // NEW: approval flag
  approval   Boolean  @default(false) // NEW: default approval is false
  // TEMP: make ownership nullable to allow migrating existing rows.
  // After backfilling userId for all rows, change back to required (User, Int).
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int?

  constructionCosts ConstructionCost[]
  unitPrices        UnitPrice[]        // NEW: back-relation for UnitPrice.project
  // NEW: back relation for ConstructionCost.referenceProject
  referencedByConstructionCosts ConstructionCost[] @relation("ConstructionCostReferenceProject")
}

model ConstructionCost {
  id                    Int      @id @default(autoincrement())
  workcode              String  // NEW
  uraian                String
  specification         String?
  qty                   Float
  satuan                String
  hargaSatuan           Float
  totalHarga            Float
  aaceClass             Int
  accuracyLow           Float    // Changed from Int to Float
  accuracyHigh          Float    // Changed from Int to Float
  tahun                 Int
  infrastruktur         String
  volume                Float
  satuanVolume          String
  kelompok              String
  kelompokDetail        String
  lokasi                String
  tipe                  String
  createdAt             DateTime @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade) // Add onDelete: Cascade
  projectId Int
  // NEW: optional reference to source project used for estimation
  referenceProject   Project? @relation("ConstructionCostReferenceProject", fields: [referenceProjectId], references: [id], onDelete: SetNull)
  referenceProjectId Int?
  referenceProjectName String?
  // NEW: indexes for common query patterns
  @@index([projectId, workcode, volume])
  @@index([referenceProjectId])
}

model UnitPrice {
  id                    Int      @id @default(autoincrement())
  workcode              String  // NEW
  uraian                String
  specification         String?
  qty                   Float
  satuan                String
  hargaSatuan           Float
  totalHarga            Float
  aaceClass             Int
  accuracyLow           Float    // Changed from Int to Float
  accuracyHigh          Float    // Changed from Int to Float
  tahun                 Int
  infrastruktur         String
  volume                Float
  satuanVolume          String
  kelompok              String
  kelompokDetail        String
  proyek                String
  lokasi                String
  tipe                  String
  createdAt             DateTime @default(now())
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  Int?
  // NEW: index to optimize sync/deletion queries
  @@index([projectId, workcode, volume])
}

model cci {
  id           Int     @id @default(autoincrement())
  kodeProvinsi Int
  provinsi     String
  cci          Float
  delivery     Float   @default(0) // NEW: delivery factor/index
}

model CalculatorTotalCost {
  id            Int      @id @default(autoincrement())
  infrastructure String
  volume         Float
  unit           String
  totalCost      Float
  year           Int
  location       String
  low            Float
  high           Float
  information    String
  kategori       String?
  createdAt      DateTime @default(now())
}

model Opex {
  id             Int      @id @default(autoincrement())
  infrastructure String
  type           String
  kategoriOpex   String
  item           String
  deskripsi      String?
  hargaOpex      Float
  volume         Float
  satuanVolume   String
  tahun          Int
  lokasi         String
  project        String
  createdAt      DateTime @default(now())
}

// Mooring rule engine settings
model MooringRuleSetting {
  id                 Int      @id @default(autoincrement())

  // --- Jetty ---
  jettyMaxDepth      Float    @default(25)
  jettyMaxDistanceKm Float    @default(2)

  // --- CBM ---
  cbmMinDepth        Float    @default(15)
  cbmMaxDepth        Float    @default(70)
  cbmExposurePolicy  String   @default("SHELTERED_SEMI")

  // --- Offshore ---
  spreadMaxDepth     Float    @default(1000)

  // --- Weathervaning ---
  towerYokeMaxDepth  Float    @default(35)

  // --- Operational Behavior ---
  turretForPermanent Boolean  @default(true)
  calmForVisiting    Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Vessel {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  capacityM3          Float
  speedKnot           Float
  rentPerDayUSD       Float
  voyageTonPerDay     Float
  ballastTonPerDay    Float
  berthTonPerDay      Float
  portCostLTP         Float
  portCostDelay       Float
  portCostPerLocation Float
  createdAt           DateTime @default(now())
}

model DistanceRoute {
  id            Int      @id @default(autoincrement())
  origin        String
  destination   String
  nauticalMiles Float
  createdAt     DateTime @default(now())
  @@unique([origin, destination])
}

model OruCapex {
  id          Int      @id @default(autoincrement())
  plantName   String   @unique
  fixCapexUSD Float
  createdAt   DateTime @default(now())
}

model SupplyChainScenario {
  id         Int      @id @default(autoincrement())
  runKey     String   @unique
  terminal   String
  locations  Json
  params     Json
  demand     Json
  createdAt  DateTime @default(now())
  runs       SupplyChainRun[]
}

model SupplyChainRun {
  id         Int      @id @default(autoincrement())
  runKey     String   @unique
  scenario   SupplyChainScenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  scenarioId Int?
  terminal   String
  locations  Json
  params     Json
  demand     Json?    // CHANGED: nullable dulu untuk migrasi
  results    Json
  topResult  Json?
  reuseCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([scenarioId])
}

model Location {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String   // 'terminal' | 'plant'
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  @@index([type])
}

model RiskMatrix {
  id        Int      @id @default(autoincrement())
  riskCode  String   @unique
  variable  String
  values    Json     // key: "II.1 P1_BOP", "II.2 P2_Durasi", ...
  createdAt DateTime @default(now())
}

// ============================
// JETTY & DOLPHINS MODULE
// ============================

// Lookup: Cb default by ship type (BS 6349-4 Table 3)
model JdCbDefault {
  id       Int    @id @default(autoincrement())
  shipType String @unique // LNGC, LNGBV, SPB, Tanker, Container, Ro-Ro, Bulk
  cb       Float
  source   String @default("BS 6349-4 Table 3 / PIANC")
}

// Lookup: Berthing velocity (PIANC 2002 / BS 6349)
model JdBerthingVelocity {
  id       Int    @id @default(autoincrement())
  deltaMin Float  // displacement min (ton)
  deltaMax Float  // displacement max (ton)
  favMin   Float
  favMax   Float
  modMin   Float
  modMax   Float
  unfMin   Float
  unfMax   Float
}

// Lookup: Fender catalogue + cost
model JdFenderCatalog {
  id         Int    @id @default(autoincrement())
  fenderId   String @unique
  type       String
  energyKj   Float  // Energy rated (kJ)
  reactionKn Float  // Reaction (kN)
  deflPct    Float  // Deflection %
  heightMm   Int
  widthMm    Int
  costIdr    Float  // Cost IDR/unit
  notes      String?
  referensi  String?
}

// Lookup: Steel pipe pile properties (fy=350 MPa)
model JdPileCatalog {
  id      Int   @id @default(autoincrement())
  dMm     Float // OD (mm)
  tMm     Float // wall thickness (mm)
  massKgM Float // kg/m
  aMm2    Float // cross-section area mm²
  auM2M   Float // Au m²/m
  abMm2   Float // Ab mm²
  welCm3  Float // section modulus cm³
  mCapKnm Float // moment capacity kN·m
  iCm4    Float // second moment cm4
  eiKnm2  Float // EI kNm²
  zKnSm   Float // Z (kN s/m)
  @@index([dMm, tMm])
}

// Lookup: Quick Release Hook classes & cost
model JdQrhCatalog {
  id          Int    @id @default(autoincrement())
  classSwlKn  Float  @unique // Class SWL (kN)
  swlTon      Float
  proofFactor Float  @default(1.5)
  costIdr     Float
  typeSupplier String
  supplier    String
  tahun       Int    @default(2024)
}

// Lookup: Unit rates for CAPEX items
model JdUnitRate {
  id          Int    @id @default(autoincrement())
  rateId      String @unique // e.g. STR-001, GEN-003, MEP-001
  item        String
  rateIdr     Float
  unit        String
  keterangan  String?
  tahun       Int    @default(2024)
}

// Settings: all constants & defaults for J&D calculations
model JdSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Float
  unit  String?
  notes String?
}

// Main J&D calculation run (linked to project)
model JdCalculation {
  id        Int      @id @default(autoincrement())
  projectId Int?

  // --- A. VESSEL INPUT ---
  shipType       String  @default("LNGBV")
  tugAssist      Boolean @default(true)
  loa            Float   // m
  lpp            Float?  // m — null = auto
  beam           Float   // m
  draft          Float   // m
  cargoCapacity  Float   // m³
  displacement   Float?  // ton — null = auto-calc
  freeboard      Float?  // m — null = default
  cbOverride     Float?  // null = auto

  // --- B. BERTHING SCENARIO ---
  berthingCondition String? // Moderate / Unfavourable — null = auto
  vbOverride        Float?  // m/s — null = lookup
  gAngle            Float?  // deg — null = auto
  rRadius           Float?  // m — null = auto
  csOverride        Float?  // null = default
  ccOverride        Float?  @default(1)
  nEff              Float?  // null = default

  // --- C. SITE & MOORING ---
  waterDepth     Float   // m
  hs             Float   @default(0.5) // m
  windSpeedKnots Float   @default(20)
  currentSpeedKnots Float @default(1)
  awOverride     Float?  // m² — null = auto
  acOverride     Float?  // m² — null = auto
  waveDriftMode  String  @default("Off") // Off / User_Input / k_Wave
  exposureClass  String  @default("Moderate") // Sheltered / Moderate / Exposed
  fWaveUser      Float?  // kN — only if waveDriftMode=User_Input
  nLines         Int     @default(4)

  // --- D. STRUCTURAL CONCEPT ---
  conceptType        String @default("Jetty_Dolphins") // Jetty_Dolphins / Dolphins_Only
  trestleLength      Float  @default(600)
  nBreastingDolphins Int    @default(4)
  nMooringDolphins   Int    @default(4)
  nPilesPerBd        Int    @default(14)
  nPilesPerMd        Int    @default(11)
  leverArmH          Float  @default(12)
  penetrationDepth   Float  @default(10)
  nFendersPerBd      Int    @default(2)
  projectDuration    Int    @default(12) // months
  usdRate            Float  @default(16300)
  jettyHeadLength    Float  @default(30)
  jettyHeadWidth     Float  @default(15)
  bdPileCapLength    Float  @default(7)
  bdPileCapWidth     Float  @default(7)
  bdPileCapHeight    Float  @default(1.5)
  mdPileCapLength    Float  @default(6)
  mdPileCapWidth     Float  @default(6)
  mdPileCapHeight    Float  @default(1.5)

  // --- RESULTS (stored after calculation) ---
  results    Json?    // full calculation results JSON
  capexData  Json?    // full CAPEX BOQ JSON
  qtoData    Json?    // full QTO JSON
  summaryData Json?   // check_summary JSON

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================
// INFRASTRUCTURE LIBRARY  (single table)
// ============================

model InfraLibrary {
  id           Int      @id @default(autoincrement())
  code         String   // LNGBV, LNGC, FSRU, SPB, TRUCK, ORU, ORF, LNG_PLANT, JETTY_LNGBV, JETTY_SPB
  categoryName String
  description  String?
  variantKey   String
  label        String
  params       Json
  // drawings: [{drawKey, title, imageUrl, fileName, mimeType, order}]
  // imageUrl = "/uploads/library/<filename>" — served as static file
  drawings     Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([code, variantKey])
  @@index([code])
}